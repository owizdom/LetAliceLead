{
  "name": "letalice-lead-backend",
  "version": "1.0.0",
  "description": "LetAliceLead — Credit & procurement infrastructure for AI agents, powered by PayWithLocus",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "locus",
    "paywithlocus",
    "ai-agents",
    "agent-credit",
    "procurement",
    "usdc",
    "credit-scoring",
    "lending"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "openai": "^4.73.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "viem": "^2.47.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
