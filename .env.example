# LetAliceLead

# ─── Required ─────────────────────────────────────────────────
LOCUS_API_KEY=claw_xxx
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api

# ─── Claude reasoning (preferred — billed against your Max subscription) ─
# Long-lived OAuth token from `claude setup-token` — bills against your subscription
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxx
# Pay-per-token fallback if no OAuth token is set
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MONOLOGUE_MODEL=claude-haiku-4-5-20251001

# ─── Autonomous agent loop ────────────────────────────────────
# Alice ticks every AGENT_TICK_MS; on each tick Claude reads the full book and
# picks one tool to invoke (rescore, adjust rate, pause, resume, note, wait).
AGENT_TICK_MS=90000                # 90s between Claude reasoning ticks
DILIGENCE_DAILY_USDC_CAP=5         # halt Alice's reasoning when 24h Locus spend hits this

# ─── Cross-chain collateral monitor ──────────────────────────
COLLATERAL_TICK_MS=120000          # 120s — refresh every active loan's pledged collateral

# ─── Sovra (sovra.dev) vendor — programmatic bidding ─────────
# Self-custodial wallet Alice uses to bid on Sovra's auction. Needs a small
# USDC balance (1-2 USDC per bid) plus ~0.00005 ETH for two contract calls.
# If unset, promote_via_sovra falls back to intent-only logging + the
# unauthenticated /api/auction/request POST (no on-chain bid lands).
SOVRA_BID_PRIVATE_KEY=
SOVRA_BID_WALLET=

# ─── Live integrations ───────────────────────────────────────
# Override the default public bobIsAlive instance
BOB_API_URL=https://bob-production-2c39.up.railway.app

# ─── Dashboard ────────────────────────────────────────────────
# Used by the Next.js dashboard to reach Alice. Point at your deployed Alice URL.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Managed wallets (credit cards) ──────────────────────────
# Encrypts the private keys Alice holds for agent-managed wallets.
# Generate with: openssl rand -hex 32
ALICE_WALLET_MASTER_KEY=
# Base mainnet RPC — used by viem to read balances and sign USDC transfers
BASE_RPC_URL=https://mainnet.base.org

# ─── Server ──────────────────────────────────────────────────
PORT=3001
BANK_NAME=LetAliceLead
CORS_ORIGIN=*
RISK_CHECK_INTERVAL_MS=60000
