# LetAliceLead

# ─── Required ─────────────────────────────────────────────────
LOCUS_API_KEY=claw_xxx
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api

# ─── LLM for credit scoring (optional, falls back to algorithmic) ─
OPENAI_API_KEY=sk-xxx
# Alternative key name accepted by the adapter
LOCUS_LLM_KEY=
# Override the LLM endpoint if routing through a proxy
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─── Live integrations ───────────────────────────────────────
# Override the default public bobIsAlive instance
BOB_API_URL=https://bob-production-2c39.up.railway.app

# ─── Dashboard ────────────────────────────────────────────────
# Used by the Next.js dashboard to reach Alice. Point at your deployed Alice URL.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Managed wallets (credit cards) ──────────────────────────
# Encrypts the private keys Alice holds for agent-managed wallets.
# Generate with: openssl rand -hex 32
ALICE_WALLET_MASTER_KEY=
# Base mainnet RPC — used by viem to read balances and sign USDC transfers
BASE_RPC_URL=https://mainnet.base.org

# ─── Server ──────────────────────────────────────────────────
PORT=3001
BANK_NAME=LetAliceLead
CORS_ORIGIN=*
RISK_CHECK_INTERVAL_MS=60000
