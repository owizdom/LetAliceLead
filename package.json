{
  "name": "let-alice-lead",
  "private": true,
  "workspaces": ["alice", "dashboard"],
  "scripts": {
    "dev": "concurrently \"npm run dev:alice\" \"npm run dev:dashboard\"",
    "dev:alice": "cd alice && npm run dev",
    "dev:dashboard": "cd dashboard && npm run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
